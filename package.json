{
  "name": "bibi-dice",
  "productName": "BIBI DICE 比比丟八",
  "version": "0.1.0",
  "scripts": {
    "steam:build": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/publish-steam-demo.ps1",
    "steam:package": "npm run steam:build -- --OutputDir dist/steam-demo && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/package-steam-windows.ps1",
    "steam:package:verify": "npm run steam:package && node scripts/verify-steam-windows-build.js",
    "steam:app": "npm run steam:build -- --OutputDir dist/steam-demo && electron steam-app/main.js",
    "steam:app:dev": "electron steam-app/main.js",
    "steam:verify": "npm run steam:build -- --OutputDir dist/steam-demo && node scripts/verify-steam-electron.js",
    "steam:capture": "npm run steam:build -- --OutputDir dist/steam-demo && node scripts/capture-steam-portrait-screenshots.js",
    "steam:capsules": "node scripts/generate-steam-capsules.js",
    "steam:assets:verify": "node scripts/verify-steam-assets.js",
    "steam:i18n:verify": "node scripts/verify-i18n.js",
    "steam:library": "node scripts/generate-steam-library-assets.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "electron": "^42.1.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0"
  }
}
