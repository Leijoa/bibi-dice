{
  "name": "bibi-dice",
  "productName": "BIBI DICE 比比丟八",
  "version": "1.0.0",
  "scripts": {
    "steam:build": "npm run steam:build:demo",
    "steam:build:demo": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/publish-steam-demo.ps1 --OutputDir dist/steam-demo",
    "steam:build:full": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/publish-steam-demo.ps1 --OutputDir dist/steam-full",
    "steam:package": "npm run steam:package:full",
    "steam:package:demo": "npm run steam:build:demo && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/package-steam-windows.ps1 -WebDistDir dist/steam-demo",
    "steam:package:full": "npm run steam:build:full && powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/package-steam-windows.ps1 -WebDistDir dist/steam-full",
    "steam:package:verify": "npm run steam:package:full && node scripts/verify-steam-windows-build.js",
    "steam:app": "npm run steam:build:demo && electron steam-app/main.js",
    "steam:app:full": "npm run steam:build:full && powershell.exe -NoProfile -Command \"$env:BIBI_DICE_STEAM_WEB_DIST='steam-full'; electron steam-app/main.js\"",
    "steam:app:dev": "electron steam-app/main.js",
    "steam:app:devcheat": "electron steam-app/main.js --bibi-dev",
    "steam:verify": "npm run steam:build:demo && node scripts/verify-steam-electron.js",
    "steam:capture": "npm run steam:build:demo && node scripts/capture-steam-portrait-screenshots.js",
    "steam:description-assets": "npm run steam:build:demo && node scripts/generate-steam-description-assets.js",
    "steam:capsules": "node scripts/generate-steam-capsules.js",
    "steam:assets:verify": "node scripts/verify-steam-assets.js",
    "steam:i18n:verify": "node scripts/verify-i18n.js",
    "test:mobile": "node --test tests/mobile-*.test.mjs",
    "mobile:build": "node scripts/build-mobile-web.js",
    "mobile:verify": "npm run mobile:build && node scripts/verify-mobile-build.js",
    "mobile:sync": "npm run mobile:build && cap sync",
    "mobile:android": "npm run mobile:sync && cap open android",
    "mobile:ios": "npm run mobile:sync && cap open ios",
    "mobile:account-deletion": "node scripts/build-account-deletion.js",
    "steam:library": "node scripts/generate-steam-library-assets.js",
    "steam:trailer": "node scripts/generate-steam-trailer-webm.js",
    "steam:trailer:finalize": "node scripts/finalize-steam-trailer.js",
    "sim": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON sim/cli.mjs",
    "sim:career": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON sim/cli.mjs --mode career",
    "sim:compare": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON sim/compare.mjs",
    "sim:verify": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON sim/verify.mjs"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@tailwindcss/cli": "^4.3.0",
    "electron": "^42.1.0",
    "esbuild": "^0.28.1",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@revenuecat/purchases-capacitor": "^13.2.1",
    "firebase": "^12.15.0",
    "steamworks.js": "^0.4.0"
  }
}
